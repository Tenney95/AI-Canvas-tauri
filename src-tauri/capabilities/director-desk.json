{
  "identifier": "director-desk-capability",
  "description": "Allow the local 3D director desk window to exchange scoped host messages",
  "windows": ["director-desk"],
  "remote": {
    "urls": ["http://127.0.0.1:5178/**"]
  },
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit"
  ]
}
