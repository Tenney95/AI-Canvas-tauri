{
  "identifier": "default",
  "description": "Default capabilities for AI Canvas",
  "windows": ["main", "asset-search"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-show",
    "core:window:allow-set-always-on-top",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-unregister-all",
    "drag:default",
    "fs:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\w+)|(file://.+)).+" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "explorer", "cmd": "explorer", "args": true },
        { "name": "mac-open", "cmd": "open", "args": true },
        { "name": "xdg-open", "cmd": "xdg-open", "args": true }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:write-files",
      "allow": [
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:read-files",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "**" }
      ]
    }
  ]
}
