{
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "productName": "AI Canvas",
    "version": "0.1.4",
    "identifier": "com.aicanvas.app",
    "plugins": {
        "shell": {
            "open": true
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "installMode": "currentUser",
                "languages": ["English", "SimpChinese"]
            }
        }
    },
    "app": {
        "withGlobalTauri": true,
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**"
                ]
            }
        },
        "windows": [
            {
                "title": "AI Canvas",
                "width": 1420,
                "height": 900,
                "minWidth": 1000,
                "minHeight": 700,
                "decorations": false,
                "transparent": true,
                "resizable": true,
                "shadow": false
            }
        ]
    }
}